CORPUSAGENT2_USE_OPENAI=true
OPENAI_API_KEY=
CORPUSAGENT2_OPENAI_BASE_URL=https://api.openai.com/v1
CORPUSAGENT2_OPENAI_PLANNER_MODEL=gpt-5.4-2026-03-05
CORPUSAGENT2_OPENAI_SYNTHESIS_MODEL=gpt-5.4-2026-03-05
CORPUSAGENT2_UNCLOSE_BASE_URL=https://hermes.ai.unturf.com/v1
CORPUSAGENT2_UNCLOSE_PLANNER_MODEL=adamo1139/Hermes-3-Llama-3.1-8B-FP8-Dynamic
CORPUSAGENT2_UNCLOSE_SYNTHESIS_MODEL=adamo1139/Hermes-3-Llama-3.1-8B-FP8-Dynamic
CORPUSAGENT2_LLM_API_KEY=choose-any-value
CORPUSAGENT2_LLM_TIMEOUT_S=60
CORPUSAGENT2_LLM_VERIFY_SSL=true

CORPUSAGENT2_OPENSEARCH_URL=https://localhost:9200
CORPUSAGENT2_OPENSEARCH_INDEX=article-corpus-opensearch
CORPUSAGENT2_OPENSEARCH_USERNAME=admin
CORPUSAGENT2_OPENSEARCH_PASSWORD=VerySecurePassword123!
CORPUSAGENT2_OPENSEARCH_VERIFY_SSL=false
CORPUSAGENT2_OPENSEARCH_TIMEOUT_S=20

CORPUSAGENT2_PG_DSN=postgresql://corpus:corpus@localhost:5432/corpus_db
CORPUSAGENT2_PG_TABLE=article_corpus
CORPUSAGENT2_RETRIEVAL_BACKEND=pgvector
CORPUSAGENT2_DEFAULT_RETRIEVAL_MODE=hybrid
CORPUSAGENT2_RETRIEVAL_USE_RERANK=true
CORPUSAGENT2_RETRIEVAL_RERANK_TOP_K=25
CORPUSAGENT2_RETRIEVAL_FUSION_K=60
CORPUSAGENT2_DENSE_MODEL_ID=intfloat/e5-base-v2
# Docker mounts this host path into CORPUSAGENT2_DOCKER_DENSE_MODEL_ID so API/MCP
# query-time dense retrieval can use a manually downloaded local model.
CORPUSAGENT2_DENSE_MODEL_HOST_PATH=../../e5-base-v2
CORPUSAGENT2_DOCKER_DENSE_MODEL_ID=/models/e5-base-v2
CORPUSAGENT2_REQUIRE_BACKEND_SERVICES=true
CORPUSAGENT2_ALLOW_LOCAL_FALLBACK=false
CORPUSAGENT2_TIME_GRANULARITY=month
CORPUSAGENT2_DEVICE=auto

CORPUSAGENT2_CORS_ORIGINS=*

CORPUSAGENT2_MCP_TRANSPORT=streamable-http
CORPUSAGENT2_MCP_HOST=0.0.0.0
CORPUSAGENT2_MCP_PORT=8765
CORPUSAGENT2_MCP_PATH=/mcp
CORPUSAGENT2_MCP_JOB_STORE=postgres
CORPUSAGENT2_MCP_MAX_CONCURRENT_JOBS=1
CORPUSAGENT2_MCP_WORKER_POLL_SECONDS=2
CORPUSAGENT2_MCP_HEARTBEAT_SECONDS=5
CORPUSAGENT2_MCP_STALE_RUNNING_SECONDS=900
CORPUSAGENT2_DOCKER_DOWNLOAD_PROVIDER_ASSETS=true
# Docker-internal defaults are set in deploy/docker-compose.mcp.yml. Override only
# if the MCP container should connect to external services.
CORPUSAGENT2_MCP_PG_DSN=
CORPUSAGENT2_MCP_OPENSEARCH_URL=

CORPUSAGENT2_PROVIDER_ORDER_TOKENIZE=spacy,stanza,nltk,regex
CORPUSAGENT2_PROVIDER_ORDER_SENTENCE_SPLIT=spacy,stanza,nltk,heuristic
CORPUSAGENT2_PROVIDER_ORDER_POS_MORPH=spacy,stanza,flair,nltk,heuristic
CORPUSAGENT2_PROVIDER_ORDER_LEMMATIZE=spacy,stanza,textblob,heuristic
CORPUSAGENT2_PROVIDER_ORDER_NER=spacy,stanza,flair,regex
CORPUSAGENT2_PROVIDER_ORDER_SENTIMENT=flair,textblob,heuristic
CORPUSAGENT2_PROVIDER_ORDER_TOPIC_MODEL=textacy,gensim,heuristic
