# Python-generated files
__pycache__/
*.py[oc]
*.pyo
build/
dist/
wheels/
*.egg-info/

# Virtual environments
.venv/

# Local uv cache
.uv-cache/

# Local environment
.env
.env.local
.env.*.local

# Generated corpus data / indexes / archives
/data/archive/
/data/raw/
/data/staged/
/data/processed/
/data/indices/

# Runtime outputs
/outputs/**
!/outputs/.gitkeep

# Logs
/log/
/logs/
*.log

# Slurm runtime logs
/slurm/*.out
/slurm/*.err
/slurm/**/*.out
/slurm/**/*.err

# VM / Docker state
/deploy/data/

# Large/generated artifacts anywhere
*.parquet
*.npy
*.npz
*.joblib
*.pkl
*.pickle
*.h5
*.hdf5
*.sqlite
*.duckdb
*.tar
*.tar.gz
*.zip

# Raw/generated JSONL only in generated dirs
/data/**/*.jsonl
/data/**/*.jsonl.gz
/outputs/**/*.jsonl
/outputs/**/*.jsonl.gz

# IDE / OS
.DS_Store
Thumbs.db
